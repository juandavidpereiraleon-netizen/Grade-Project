<HistorialScreen>:
    canvas.before:
        Color:
            rgba: 0.96, 0.97, 0.98, 1
        Rectangle:
            pos: self.pos
            size: self.size

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(22)
        spacing: dp(22)

        MDLabel:
            text: "Historial de Movimientos"
            halign: "center"
            font_style: "H4"
            text_color: 0.15, 0.15, 0.2, 1
            bold: True

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True
            bar_width: dp(8)
            bar_color: 0.2, 0.4, 0.7, 0.5
            MDGridLayout:
                id: lista
                cols: 1
                adaptive_height: True
                spacing: dp(14)
                padding: dp(12)

        MDRaisedButton:
            text: "Volver"
            md_bg_color: 0.5, 0.5, 0.55, 1
            text_color: 1, 1, 1, 1
            elevation: 4
            radius: [25,]
            size_hint_y: None
            height: dp(52)
            on_release: root.volver_meta()

<DetallePlanScreen>:
    canvas.before:
        Color:
            rgba: 0.96, 0.97, 0.98, 1
        Rectangle:
            pos: self.pos
            size: self.size

    MDBoxLayout:
        orientation: "vertical"
        padding: dp(28)
        spacing: dp(28)

        MDLabel:
            text: "Detalle del Plan"
            halign: "center"
            font_style: "H3"
            text_color: 0.15, 0.15, 0.2, 1
            bold: True

        MDCard:
            orientation: "vertical"
            padding: dp(35)
            spacing: dp(22)
            radius: [28,]
            elevation: 8
            md_bg_color: 0.98, 0.99, 1.0, 1

            MDLabel:
                id: meta_nombre
                text: "Nombre de la meta"
                halign: "center"
                font_style: "H5"
                text_color: 0.15, 0.15, 0.2, 1
                bold: True

            MDLabel:
                id: meta_fecha
                text: "Fecha límite"
                halign: "center"
                font_style: "Subtitle1"
                text_color: 0.5, 0.5, 0.55, 1

            MDLabel:
                id: meta_costo
                text: "Costo: $0"
                halign: "center"
                font_style: "H6"
                text_color: 0.2, 0.4, 0.7, 1
                bold: True

            MDLabel:
                id: meta_ahorrado
                text: "Ahorrado: $0"
                halign: "center"
                font_style: "H6"
                text_color: 0.2, 0.6, 0.5, 1
                bold: True

            MDLabel:
                id: meta_faltante
                text: "Faltante: $0"
                halign: "center"
                font_style: "H6"
                text_color: 0.75, 0.35, 0.35, 1
                bold: True

        MDRaisedButton:
            text: "Volver"
            md_bg_color: 0.5, 0.5, 0.55, 1
            text_color: 1, 1, 1, 1
            elevation: 4
            radius: [25,]
            size_hint_y: None
            height: dp(52)
            on_release: root.volver_meta()
