            MDRaisedButton:
                text: "Registrar ahorro"
                md_bg_color: 0.2, 0.6, 0.5, 1
                text_color: 1, 1, 1, 1
                elevation: 4
                radius: [25,]
                size_hint_y: None
                height: dp(52)
                on_release: root.ir_registrar_ahorro(self)

            MDRaisedButton:
                text: "Registrar salida"
                md_bg_color: 0.2, 0.4, 0.7, 1
                text_color: 1, 1, 1, 1
                elevation: 4
                radius: [25,]
                size_hint_y: None
                height: dp(52)
                on_release: root.ir_registrar_salida(self)

            MDRaisedButton:
                text: "Historial"
                md_bg_color: 0.2, 0.4, 0.7, 1
                text_color: 1, 1, 1, 1
                elevation: 4
                radius: [25,]
                size_hint_y: None
                height: dp(52)
                on_release: root.ir_historial(self)

            MDRaisedButton:
                text: "Detalle del plan"
                md_bg_color: 0.2, 0.4, 0.7, 1
                text_color: 1, 1, 1, 1
                elevation: 4
                radius: [25,]
                size_hint_y: None
                height: dp(52)
                on_release: root.ir_detalle_plan(self)

            MDRaisedButton:
                text: "Volver"
                md_bg_color: 0.5, 0.5, 0.55, 1
                text_color: 1, 1, 1, 1
                elevation: 3
                radius: [25,]
                size_hint_y: None
                height: dp(52)
                on_release: root.volver_curso(self)

<RegistrarAhorroScreen>:
    canvas.before:
        Color:
            rgba: 0.96, 0.97, 0.98, 1
